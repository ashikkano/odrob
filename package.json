{
  "name": "odrob-trading",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node scripts/dev.js",
    "start:fresh": "node scripts/dev.js --fresh",
    "start:api": "node scripts/dev.js --backend-only",
    "start:ui": "node scripts/dev.js --frontend-only",
    "dev": "node scripts/dev.js",
    "dev:fresh": "node scripts/dev.js --fresh",
    "server": "node server/index.js",
    "server:fresh": "node --input-type=module -e \"import fs from 'node:fs'; const target = process.env.SQLITE_PATH && process.env.SQLITE_PATH !== ':memory:' ? process.env.SQLITE_PATH : 'server/data/odrob.db'; for (const file of [target, `${target}-wal`, `${target}-shm`]) { try { fs.rmSync(file, { force: true }) } catch {} }\" && node server/index.js",
    "verify:tonconnect-privy": "node scripts/verify-tonconnect-privy-flow.mjs",
    "verify:user-runtime-bridge": "node scripts/verify-user-runtime-bridge.mjs",
    "verify:fees": "node scripts/verify-fee-accounting.mjs",
    "test:fees": "node scripts/verify-fee-accounting.mjs",
    "test:orderbook": "node server/engine/orderbook-v2/test.js",
    "test:llm": "node server/engine/llm/test.js",
    "test": "npm run test:fees && npm run test:orderbook && npm run test:llm",
    "db:postgres:dry-run": "node server/scripts/migrate-sqlite-to-postgres.mjs --dry-run",
    "db:postgres:migrate": "node server/scripts/migrate-sqlite-to-postgres.mjs",
    "db:postgres:verify": "node server/scripts/verify-postgres-migration.mjs",
    "lint": "eslint . --ext js,mjs,jsx",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "soak:seed-indexes": "node scripts/seed-agent-index-soak.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "docs:generate": "node scripts/generate-docs.js"
  },
  "dependencies": {
    "@privy-io/react-auth": "^2.13.4",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@solana-program/system": "^0.7.0",
    "@solana-program/token": "^0.5.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@ton/core": "^0.63.1",
    "@tonconnect/ui-react": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.4.0",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
